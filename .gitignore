# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
venv-somali/
env/
ENV/
*.bak

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data: regenerate via pipelines, do not commit.
# Note: gitignore does NOT support inline comments; patterns must stand alone.
data/silver/
data/bronze/
data/gold/
data/staging/
data/processed/
data/raw/
data/ledger/
data/analysis/
data/metrics/
data/reports/
data/manifests/
*.pkl
*.h5
*.parquet
*.jsonl
*.db

# Dashboard cache
dashboard/data/

# Models (use Git LFS or external storage)
models/*.bin
models/*.pt
*.safetensors

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs (runtime artifacts)
logs/*
!logs/.gitkeep
*.log

# Lock files (distributed locking for concurrent runs)
.locks/
*.lock

# Secrets - ignore ALL .env variants to prevent secret exposure
.env*
!.env.example
*.key

# Development artifacts (archived planning documents)
.archive/
.backups/
audits/

# Internal governance (rubrics, threat model, RAI register, SLO/SLI, scorecards)
# Public subset lives under docs/governance/ and stays tracked.
governance/

# Testing and coverage artifacts
.coverage
coverage.json
# Temporary test files at root level
/test_*.py

# Internal deployment and operational documents (archive before committing)
*_DEPLOYMENT_SUCCESS.md
*_SUCCESS.md
POSTGRES_DEPLOYMENT_SUCCESS.md

# GitHub Pages build artifacts
_site/

# MLflow experiment artifacts (regenerate via pipelines)
mlruns/

# Local testing artifacts (Playwright, etc.)
# NOTE: playwright.config.js is intentionally NOT ignored — it is the tracked,
# canonical Playwright config (webServer/baseURL/projects) required by CI.
.playwright-mcp/
test-results/
tests/screenshots/
tests/*-navigation.js
tests/test_dashboard_calculation_unit.py
scripts/analyze_success_rate.py
dashboard/index-advanced.html
dashboard/js/demo-*.js
design-system-*.html

# TikTok integration testing directory
tiktok_apify_test/
node_modules/
*-snapshots/

# Claude Code configuration
.claude/
CLAUDE.md

# Codex local configuration and project-local agent/skill assets
.agents/
.codex/
AGENTS.md
AGENTS.override.md

# MetaEnsemble: per-project working directory (Ledger, manifests, backups,
# inspection output). Re-derivable per machine — do not commit.
.metaensemble/

# Local data backups (large tarballs, never committed)
data/backups/
